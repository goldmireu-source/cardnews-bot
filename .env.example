# 환경변수 템플릿 — 실제 값은 .env 에 넣으세요(.env 는 git 제외)
# === 웹 로그인 인증 ===
WEB_USERNAME=admin
WEB_PASSWORD=
SECRET_KEY=
TELEGRAM_BOT_TOKEN=
ANTHROPIC_API_KEY=
SERVER_URL=
ALLOWED_USERS=
MODEL=
PORT=
FB_APP_ID=
FB_APP_SECRET=
FB_PAGE_ID=
IG_USER_ID=
FB_PAGE_ACCESS_TOKEN=
IG_ACCESS_TOKEN=
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_ACCESS_TOKEN=
