# --- 텔레그램 코딩봇 (code_agent_bot.py) — 선택 ---
# 채팅으로 코드 수정·명령 실행·git 동기화. ⚠️ 원격 코드 실행이므로 허용 ID 필수.
CODE_BOT_TOKEN=          # @BotFather 토큰 (TELEGRAM_BOT_TOKEN 과 별도의 새 봇)
CODE_BOT_ALLOWED_IDS=    # 허용 텔레그램 사용자 ID, 쉼표구분. 봇 띄운 뒤 /whoami 로 확인
CODE_BOT_CWD=            # 기본 작업 레포 경로 (비우면 code_agent_bot.py 가 있는 폴더)
# 여러 프로젝트를 /project 로 전환해 쓰려면(선택, 비우면 코드의 기본 3개 사용):
# CODE_BOT_PROJECTS=cardnews=f:\cardnews_bot\cardnews_bot;dailysync=f:\ai-news-digest\ai-news-digest;studiohub=f:\studio_app
